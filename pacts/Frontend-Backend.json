{
  "consumer": {
    "name": "Frontend"
  },
  "interactions": [
    {
      "description": "une requête pour créer un post",
      "providerStates": [
        {
          "name": "le backend accepte un nouveau post"
        }
      ],
      "request": {
        "body": {
          "body": "Contenu",
          "title": "Nouveau post",
          "userId": 1
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.body": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.title": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.userId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/posts"
      },
      "response": {
        "body": {
          "body": "Contenu",
          "id": 3,
          "title": "Nouveau post",
          "userId": 1
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.body": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.title": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.userId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            }
          }
        },
        "status": 201
      }
    },
    {
      "description": "une requête pour récupérer le post 1",
      "providerStates": [
        {
          "name": "un post avec ID 1 existe"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/posts/1"
      },
      "response": {
        "body": {
          "body": "Contenu 1",
          "id": 1,
          "title": "Premier post",
          "userId": 1
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.body": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.title": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.userId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.3.0"
    },
    "pactRust": {
      "ffi": "0.5.3",
      "models": "1.3.9"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "Backend"
  }
}