          "name": "POST - Créer un post valide",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Statut est 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Le post créé a un id\", function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.id).to.be.a(\"number\");",
                  "});",
                  "",
                  "pm.test(\"Le titre correspond\", function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.title).to.equal(\"Mon premier post\");",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Mon premier post\",\n  \"body\": \"Contenu de test\",\n  \"userId\": 1\n}",
              "options": {
